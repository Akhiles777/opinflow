generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model User {
  id                String              @id @default(cuid())
  email             String              @unique
  emailVerified     DateTime?
  name              String?
  image             String?
  passwordHash      String?
  referralCode      String?             @unique
  role              Role                @default(RESPONDENT)
  status            UserStatus          @default(PENDING_VERIFICATION)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  accounts          Account[]
  sessions          Session[]
  respondentProfile RespondentProfile?
  clientProfile     ClientProfile?
  wallet            Wallet?
  surveysCreated    Survey[]            @relation("SurveyCreator")
  surveyResponses   SurveyResponse[]
  referralsSent     Referral[]          @relation("ReferralSender")
  referralsReceived Referral[]          @relation("ReferralReceiver")
  emailTokens       EmailToken[]
  surveySessions    SurveySession[]
  complaintsSent    Complaint[]
  payments          Payment[]
  withdrawalRequests WithdrawalRequest[]
  expertReviewRequests ExpertReviewRequest[]
  pushSubscriptions PushSubscription[]
  notifications     Notification[]
  invoices          Invoice[]
  surveyTemplates   SurveyTemplate[]  @relation("TemplateCreator")
  @@map("users")
}

enum Role {
  RESPONDENT
  CLIENT
  ADMIN
}

enum UserStatus {
  ACTIVE
  PENDING_VERIFICATION
  BLOCKED
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model EmailToken {
  id        String         @id @default(cuid())
  userId    String
  token     String         @unique @default(cuid())
  type      EmailTokenType
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime       @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_tokens")
}

enum EmailTokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

model RespondentProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  gender           String?
  birthDate        DateTime?
  city             String?
  income           String?
  education        String?
  hasChildren      String?
  employmentStatus String?
  industry         String?
  maritalStatus    String?
  interests        String[]
  isVerified       Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  image            String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("respondent_profiles")
}

model ClientProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  companyName  String?
  inn          String?
  contactName  String?
  phone        String?
  legalAddress String?
  bankName     String?
  bankAccount  String?
  bankBik      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("client_profiles")
}

model Wallet {
  id          String        @id @default(cuid())
  userId      String        @unique
  balance     Decimal       @default(0) @db.Decimal(10, 2)
  totalEarned Decimal       @default(0) @db.Decimal(10, 2)
  totalSpent  Decimal       @default(0) @db.Decimal(10, 2)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@map("wallets")
}

model Transaction {
  id          String            @id @default(cuid())
  walletId    String
  type        TransactionType
  amount      Decimal           @db.Decimal(10, 2)
  description String?
  status      TransactionStatus @default(PENDING)
  createdAt   DateTime          @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

enum TransactionType {
  EARNING
  WITHDRAWAL
  DEPOSIT
  SPENDING
  REFUND
  BONUS
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

model Survey {
  id              String       @id @default(cuid())
  creatorId       String
  title           String
  description     String?
  category        String?
  status          SurveyStatus @default(DRAFT)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  maxResponses    Int?
  reward          Decimal?     @db.Decimal(10, 2)
  estimatedTime   Int?
  budget          Decimal?     @db.Decimal(10, 2)
  platformFee     Decimal?     @db.Decimal(10, 2)
  targetGender    String?
  targetAgeMin    Int?
  targetAgeMax    Int?
  targetCities    String[]
  targetIncomes   String[]
  targetInterests String[]
  targetHasChildren String?
  targetEmploymentStatuses String[]
  targetIndustries String[]
  targetMaritalStatuses String[]
  startsAt        DateTime?
  endsAt          DateTime?
  moderationNote  String?
  generatedByAI   Boolean   @default(false)
  aiPrompt        String?
  aiIndustry      String?
  aiTargetAudience String?
  draftStep       Int?
  surveyMode      String    @default("POOL")   // "POOL" | "SELF_SERVICE"
  publicLinkSlug  String?   @unique
  aiAnalyticsPaid    Boolean   @default(false)
  aiAnalyticsPaidAt  DateTime?

  creator    User             @relation("SurveyCreator", fields: [creatorId], references: [id])
  responses  SurveyResponse[]
  questions  SurveyQuestion[]
  sessions   SurveySession[]
  complaints Complaint[]
  analysis   SurveyAnalysis?
  expertReviewRequests ExpertReviewRequest[]

  @@map("surveys")
}

enum SurveyStatus {
  DRAFT
  PENDING_MODERATION
  ACTIVE
  PAUSED
  COMPLETED
  REJECTED
}

model SurveyQuestion {
  id          String       @id @default(cuid())
  surveyId    String
  order       Int
  type        QuestionType
  title       String
  description String?
  required    Boolean      @default(true)
  mediaUrl    String?
  options     Json?
  settings    Json?
  logic       Json?
  createdAt   DateTime     @default(now())

  survey  Survey         @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  answers SurveyAnswer[]

  @@map("survey_questions")
}

enum QuestionType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  SCALE
  MATRIX
  RANKING
  OPEN_TEXT
}

model SurveySession {
  id          String        @id @default(cuid())
  surveyId    String
  userId      String
  status      SessionStatus @default(IN_PROGRESS)
  startedAt   DateTime      @default(now())
  completedAt DateTime?
  timeSpent   Int?
  ipAddress   String?
  userAgent   String?
  deviceId    String?
  isValid     Boolean       @default(true)
  fraudFlags  String[]

  survey   Survey          @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers  SurveyAnswer[]
  response SurveyResponse?

  @@unique([surveyId, userId])
  @@map("survey_sessions")
}

enum SessionStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
  REJECTED
}

model SurveyAnswer {
  id         String   @id @default(cuid())
  sessionId  String
  questionId String
  value      Json
  createdAt  DateTime @default(now())

  session  SurveySession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question SurveyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, questionId])
  @@map("survey_answers")
}

model Complaint {
  id         String          @id @default(cuid())
  fromUserId String
  surveyId   String?
  sessionId  String?
  reason     String
  details    String?
  status     ComplaintStatus @default(PENDING)
  createdAt  DateTime        @default(now())

  fromUser User    @relation(fields: [fromUserId], references: [id])
  survey   Survey? @relation(fields: [surveyId], references: [id])

  @@map("complaints")
}

enum ComplaintStatus {
  PENDING
  REVIEWED
  RESOLVED
  DISMISSED
}

model SurveyResponse {
  id               String    @id @default(cuid())
  surveyId         String
  userId           String
  sessionId        String?   @unique
  moderationStatus String    @default("PENDING")
  moderationNote   String?
  moderatedAt      DateTime?
  moderatedBy      String?
  createdAt        DateTime  @default(now())

  survey  Survey         @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  session SurveySession? @relation(fields: [sessionId], references: [id])

  @@unique([surveyId, userId])
  @@map("survey_responses")
}

model Referral {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String   @unique
  bonusPaid  Boolean  @default(false)
  createdAt  DateTime @default(now())

  sender   User @relation("ReferralSender", fields: [senderId], references: [id])
  receiver User @relation("ReferralReceiver", fields: [receiverId], references: [id])

  @@map("referrals")
}

model Payment {
  id              String        @id @default(cuid())
  userId          String
  yukassaId       String?       @unique
  ozonExtId       String?       @unique
  ozonPaymentId   String?
  type            PaymentType
  amount          Decimal       @db.Decimal(10, 2)
  status          PaymentStatus @default(PENDING)
  description     String?
  metadata        Json?
  confirmationUrl String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("payments")
}

enum PaymentType {
  DEPOSIT
  PAYOUT
}

enum PaymentStatus {
  PENDING
  WAITING
  SUCCEEDED
  CANCELED
  FAILED
}

model WithdrawalRequest {
  id              String           @id @default(cuid())
  userId          String
  amount          Decimal          @db.Decimal(10, 2)
  method          WithdrawalMethod
  requisites      Json
  status          WithdrawalStatus @default(PENDING)
  yukassaPayoutId String?
  adminNote       String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("withdrawal_requests")
}

enum WithdrawalMethod {
  CARD
  SBP
  WALLET
}

enum WithdrawalStatus {
  PENDING
  PROCESSING
  COMPLETED
  REJECTED
  FAILED
}

model SurveyAnalysis {
  id            String         @id @default(cuid())
  surveyId      String         @unique
  status        AnalysisStatus @default(PENDING)
  themes        Json?
  sentimentData Json?
  wordCloud     Json?
  diagnostics   Json?
  summary       String?
  keyInsights   Json?
  pdfUrl        String?
  generatedAt   DateTime?
  error         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  survey Survey @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  @@map("survey_analyses")
}

enum AnalysisStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model AppSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @default(now()) @updatedAt

  @@map("app_settings")
}

// ══════════════════════════════════════════════════════════
// PUSH ПОДПИСКИ
// ══════════════════════════════════════════════════════════

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}




// ══════════════════════════════════════════════════════════
// УВЕДОМЛЕНИЯ В БАЗЕ (история)
// ══════════════════════════════════════════════════════════

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  link      String?          // куда вести при клике
  isRead    Boolean          @default(false)
  sentEmail Boolean          @default(false)
  sentPush  Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model ExpertReviewRequest {
  id             String             @id @default(cuid())
  surveyId       String
  userId         String
  amount         Decimal            @db.Decimal(10, 2)
  status         ExpertReviewStatus @default(PENDING)
  assignedExpert String?
  adminNote      String?
  reportUrl      String?
  reportText     String?  @db.Text
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  completedAt    DateTime?

  survey Survey @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([surveyId, userId])
  @@map("expert_review_requests")
}

enum ExpertReviewStatus {
  PENDING
  ASSIGNED
  COMPLETED
  REJECTED
}

enum NotificationType {
  NEW_SURVEY           // новый доступный опрос (респонденту)
  EARNING_CREDITED     // начислено вознаграждение
  WITHDRAWAL_STATUS    // статус вывода изменился
  SURVEY_APPROVED      // опрос одобрен (заказчику)
  SURVEY_REJECTED      // опрос отклонён (заказчику)
  SURVEY_COMPLETED     // опрос набрал нужное число ответов
  REFERRAL_BONUS       // реферальный бонус
  SYSTEM               // системное сообщение
}

model PlatformSettings {
  id                String   @id @default("singleton")
  commissionPercent Decimal  @default(15) @db.Decimal(5, 2)
  minWithdrawal     Decimal  @default(100) @db.Decimal(10, 2)
  minReward         Decimal  @default(20) @db.Decimal(10, 2)
  maintenanceMode   Boolean  @default(false)
  adminEmail        String   @default("")
  updatedAt         DateTime @updatedAt

  @@map("platform_settings")
}

model Expert {
  id        String   @id @default(cuid())
  name      String
  email     String?
  specialty String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("experts")
}

model Invoice {
  id        Int      @id @default(autoincrement())
  paymentId String?
  userId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("invoices")
}

model SurveyTemplate {
  id        String   @id @default(cuid())
  creatorId String
  name      String
  questions Json
  createdAt DateTime @default(now())

  creator User @relation("TemplateCreator", fields: [creatorId], references: [id], onDelete: Cascade)

  @@map("survey_templates")
}
